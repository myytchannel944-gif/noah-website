---
import { ClientRouter } from 'astro:transitions';

const defaultTitle = '\u{1D593}\u{1D594}\u{1D586}\u{1D58D}\u30B7\u2671';
const { title = defaultTitle } = Astro.props;
const { bodyClass = 'home-page' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" href="/assets/favicon.ico" type="image/webp" />
    <ClientRouter />

    <style is:global>
      body {
        margin: 0;
        background: #050505;
        color: #eaeaea;
        font-family: Inter, system-ui, sans-serif;
      }

      body.home-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
      }

      .home-wrap {
        width: min(100%, 980px);
        padding: 72px 24px 96px;
        animation: fade 1s ease-out;
        position: relative;
        z-index: 1;
      }

      .home-wrap h1 {
        font-size: clamp(3.4rem, 10vw, 7rem);
        font-weight: 700;
        letter-spacing: -2px;
        margin: 0;
        background-image: url('/assets/paint.avif');
        background-size: cover;
        background-position: center;
        color: transparent;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        -webkit-background-clip: text;
      }

      .hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
        gap: 40px;
        align-items: center;
        min-height: calc(100vh - 168px);
      }

      .hero-copy {
        text-align: left;
      }

      .eyebrow {
        margin: 0 0 16px;
        color: #777;
        font-size: 0.78rem;
        letter-spacing: 1.4px;
        text-transform: uppercase;
      }

      .hero-copy p {
        max-width: 580px;
        color: #a5a5a5;
        font-size: 1.05rem;
        line-height: 1.75;
        margin: 20px 0 0;
      }

      .home-wrap .tagline {
        margin-top: 18px;
        color: #8a8a8a;
        font-size: 1.1rem;
        line-height: 1.6;
      }

      .home-wrap .roles {
        margin: 22px 0 0;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .pill {
        border: 1px solid rgba(255, 255, 255, 0.09);
        border-radius: 999px;
        color: #d7d7d7;
        background: rgba(255, 255, 255, 0.03);
        padding: 8px 13px;
        font-size: 0.84rem;
      }

      .home-wrap .links {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 32px;
      }

      .home-wrap .links a {
        min-height: 42px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255, 255, 255, 0.09);
        border-radius: 8px;
        padding: 0 15px;
        color: #d8d8d8;
        background: rgba(255, 255, 255, 0.035);
        text-decoration: none;
        transition: 0.2s ease;
      }

      .home-wrap .links a:hover {
        color: white;
        transform: translateY(-2px);
        border-color: rgba(255, 255, 255, 0.2);
      }

      .featured-strip {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        margin-top: 0;
      }

      .mini-card {
        border: 1px solid rgba(255, 255, 255, 0.07);
        background: rgba(255, 255, 255, 0.025);
        border-radius: 10px;
        padding: 14px;
        text-align: left;
      }

      .mini-card span {
        display: block;
        color: #777;
        font-size: 0.74rem;
        text-transform: uppercase;
        letter-spacing: 1px;
      }

      .mini-card strong {
        display: block;
        margin-top: 7px;
        color: #f1f1f1;
        font-size: 0.95rem;
        font-weight: 500;
      }

      .portfolio-section {
        margin-top: 72px;
      }

      .portfolio-head {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        align-items: end;
        margin-bottom: 18px;
      }

      .portfolio-head h2 {
        margin: 0;
        font-size: 1.65rem;
        font-weight: 600;
        letter-spacing: -0.5px;
      }

      .portfolio-head p {
        max-width: 440px;
        margin: 0;
        color: #777;
        line-height: 1.6;
      }

      .portfolio-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
      }

      .portfolio-card {
        border: 1px solid rgba(255, 255, 255, 0.075);
        border-radius: 12px;
        padding: 22px;
        min-height: 148px;
        background:
          linear-gradient(145deg, rgba(145, 70, 255, 0.09), rgba(255, 255, 255, 0.025)),
          rgba(255, 255, 255, 0.02);
      }

      .portfolio-card h3 {
        margin: 0;
        color: #fff;
        font-size: 1.12rem;
        font-weight: 600;
      }

      .portfolio-card p {
        margin: 12px 0 0;
        color: #9a9a9a;
        line-height: 1.65;
      }

      .portfolio-card a {
        display: inline-flex;
        margin-top: 18px;
        color: #d8c4ff;
        text-decoration: none;
        font-size: 0.92rem;
      }

      .portfolio-card a:hover {
        color: #fff;
      }

      @keyframes fade {
        from {
          opacity: 0;
          transform: translateY(10px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .home-footer {
        margin: 48px 0 0;
        text-align: center;
        font-size: 0.85rem;
        color: #444;
        width: 100%;
        z-index: 1;
      }

      .enter-screen {
        position: fixed;
        inset: 0;
        z-index: 10;
        display: grid;
        place-items: center;
        background:
          radial-gradient(circle at 50% 42%, rgba(145, 70, 255, 0.18), transparent 34%),
          rgba(5, 5, 5, 0.96);
        transition: opacity 0.35s ease, visibility 0.35s ease;
      }

      .enter-screen.is-hidden {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
      }

      .enter-screen span {
        position: absolute;
        bottom: 32px;
        color: #555;
        font-size: 0.78rem;
        letter-spacing: 1px;
        text-transform: uppercase;
      }

      .enter-button {
        width: 120px;
        height: 120px;
        border: 1px solid rgba(255, 255, 255, 0.13);
        border-radius: 999px;
        color: #f4f4f4;
        background: rgba(255, 255, 255, 0.04);
        font: inherit;
        font-size: 1rem;
        cursor: pointer;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        transition: 0.2s ease;
        box-shadow: 0 0 80px rgba(145, 70, 255, 0.22);
      }

      .enter-button:hover {
        transform: scale(1.05);
        border-color: rgba(255, 255, 255, 0.32);
        background: rgba(145, 70, 255, 0.16);
      }

      .inner-wrap {
        max-width: 900px;
        margin: 0 auto;
        padding: 80px 24px;
      }

      .top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 60px;
      }

      .logo {
        font-size: 1.2rem;
        color: #aaa;
        text-decoration: none;
      }

      .back {
        color: #666;
        text-decoration: none;
        font-size: 0.9rem;
        transition: 0.2s;
      }

      .back:hover {
        color: #fff;
      }

      .inner-wrap h1 {
        font-size: 3rem;
        font-weight: 600;
        margin: 0 0 10px 0;
        letter-spacing: -1px;
      }

      .sub {
        color: #777;
        max-width: 500px;
        margin-bottom: 60px;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 18px;
      }

      .card {
        border: 1px solid rgba(255, 255, 255, 0.06);
        padding: 18px;
        border-radius: 10px;
        transition: 0.2s ease;
      }

      .card:hover {
        transform: translateY(-4px);
        border-color: rgba(255, 255, 255, 0.15);
      }

      .card h3 {
        margin: 0 0 6px 0;
        font-weight: 500;
        font-size: 1.1rem;
      }

      .card p {
        margin: 0;
        color: #888;
        font-size: 0.9rem;
        line-height: 1.4;
      }

      .footer {
        margin-top: 80px;
        color: #444;
        font-size: 0.85rem;
      }

      .card-link {
        text-decoration: none;
        color: inherit;
        display: block;
      }

      .card-link .card {
        cursor: pointer;
      }

      .button-row {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin: 28px 0 56px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        border-radius: 8px;
        padding: 0 16px;
        color: #fff;
        background: #9146ff;
        text-decoration: none;
        font-size: 0.92rem;
        font-weight: 600;
        transition: 0.2s ease;
      }

      .button:hover {
        transform: translateY(-2px);
        background: #a970ff;
      }

      .button.secondary {
        color: #d8d8d8;
        background: rgba(255, 255, 255, 0.06);
      }

      .button.secondary:hover {
        color: #fff;
        background: rgba(255, 255, 255, 0.1);
      }

      .card-row {
        display: flex;
        align-items: center;
        gap: 14px;
      }

      .icon {
        width: 36px;
        height: 36px;
        object-fit: contain;
        opacity: 0.9;
        transition: 0.2s;
      }

      .card-link:hover .icon {
        transform: scale(1.1);
        opacity: 1;
      }

      .section-title {
        margin: 40px 0 16px;
        font-size: 1rem;
        font-weight: 500;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 1px;
      }

      .profile-card {
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        padding: 22px;
        background: linear-gradient(135deg, rgba(145, 70, 255, 0.14), rgba(255, 255, 255, 0.025));
      }

      .profile-row {
        display: flex;
        align-items: center;
        gap: 18px;
      }

      .avatar {
        width: 76px;
        height: 76px;
        flex: 0 0 auto;
        border-radius: 18px;
        display: grid;
        place-items: center;
        color: #fff;
        font-size: 1.5rem;
        font-weight: 700;
        background:
          linear-gradient(135deg, rgba(145, 70, 255, 0.95), rgba(35, 211, 171, 0.88)),
          #222;
        box-shadow: 0 16px 42px rgba(0, 0, 0, 0.35);
      }

      .profile-card h2,
      .profile-card p {
        margin: 0;
      }

      .profile-card h2 {
        font-size: 1.35rem;
        font-weight: 600;
      }

      .profile-card p {
        margin-top: 6px;
        color: #9b9b9b;
        line-height: 1.5;
      }

      .detail-list {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
        gap: 14px;
        margin-top: 28px;
      }

      .detail {
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 10px;
        padding: 16px;
        background: rgba(255, 255, 255, 0.025);
      }

      .detail span {
        display: block;
        color: #777;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
      }

      .detail strong {
        display: block;
        margin-top: 8px;
        font-size: 1rem;
        font-weight: 500;
      }

      .about-copy {
        max-width: 680px;
        color: #a7a7a7;
        line-height: 1.8;
      }

      @media (max-width: 640px) {
        .home-wrap h1 {
          font-size: 3rem;
        }

        .home-wrap {
          padding-top: 48px;
        }

        .hero-grid,
        .portfolio-grid {
          grid-template-columns: 1fr;
        }

        .hero-grid {
          min-height: auto;
          gap: 28px;
        }

        .home-wrap .links {
          gap: 10px;
        }

        .featured-strip {
          grid-template-columns: 1fr;
        }

        .portfolio-head {
          display: block;
        }

        .portfolio-head p {
          margin-top: 10px;
        }

        .profile-row {
          align-items: flex-start;
          flex-direction: column;
        }
      }
    </style>
  </head>

  <body class={bodyClass}>
    <audio id="intro-audio" src="/audio/evil-jordan.mp3" preload="auto" data-start="0" transition:persist></audio>
    <slot />
  </body>
</html>
