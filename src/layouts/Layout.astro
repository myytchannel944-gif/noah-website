---
const defaultTitle = '\u{1D593}\u{1D594}\u{1D586}\u{1D58D}\u30B7\u2671';
const { title = defaultTitle } = Astro.props;
const { bodyClass = 'home-page' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" href="/assets/favicon.ico" type="image/webp" />

    <style is:global>
      body {
        margin: 0;
        background: #050505;
        color: #eaeaea;
        font-family: Inter, system-ui, sans-serif;
      }

      body.home-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }

      .home-wrap {
        text-align: center;
        max-width: 600px;
        padding: 20px;
        animation: fade 1s ease-out;
      }

      .home-wrap h1 {
        font-size: 4rem;
        font-weight: 700;
        letter-spacing: -2px;
        margin: 0;
        background-image: url('/assets/paint.avif');
        background-size: cover;
        background-position: center;
        color: transparent;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        -webkit-background-clip: text;
      }

      .home-wrap .tagline {
        margin-top: 18px;
        color: #8a8a8a;
        font-size: 1.1rem;
        line-height: 1.6;
      }

      .home-wrap .links {
        margin-top: 45px;
      }

      .home-wrap .links a {
        margin: 0 14px;
        color: #aaa;
        text-decoration: none;
        transition: 0.2s ease;
      }

      .home-wrap .links a:hover {
        color: white;
      }

      @keyframes fade {
        from {
          opacity: 0;
          transform: translateY(10px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .home-footer {
        position: absolute;
        bottom: 20px;
        text-align: center;
        font-size: 0.85rem;
        color: #444;
        width: 100%;
      }

      .inner-wrap {
        max-width: 900px;
        margin: 0 auto;
        padding: 80px 24px;
      }

      .top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 60px;
      }

      .logo {
        font-size: 1.2rem;
        color: #aaa;
        text-decoration: none;
      }

      .back {
        color: #666;
        text-decoration: none;
        font-size: 0.9rem;
        transition: 0.2s;
      }

      .back:hover {
        color: #fff;
      }

      .inner-wrap h1 {
        font-size: 3rem;
        font-weight: 600;
        margin: 0 0 10px 0;
        letter-spacing: -1px;
      }

      .sub {
        color: #777;
        max-width: 500px;
        margin-bottom: 60px;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 18px;
      }

      .card {
        border: 1px solid rgba(255, 255, 255, 0.06);
        padding: 18px;
        border-radius: 10px;
        transition: 0.2s ease;
      }

      .card:hover {
        transform: translateY(-4px);
        border-color: rgba(255, 255, 255, 0.15);
      }

      .card h3 {
        margin: 0 0 6px 0;
        font-weight: 500;
        font-size: 1.1rem;
      }

      .card p {
        margin: 0;
        color: #888;
        font-size: 0.9rem;
        line-height: 1.4;
      }

      .footer {
        margin-top: 80px;
        color: #444;
        font-size: 0.85rem;
      }

      .card-link {
        text-decoration: none;
        color: inherit;
        display: block;
      }

      .card-link .card {
        cursor: pointer;
      }

      .card-row {
        display: flex;
        align-items: center;
        gap: 14px;
      }

      .icon {
        width: 36px;
        height: 36px;
        object-fit: contain;
        opacity: 0.9;
        transition: 0.2s;
      }

      .card-link:hover .icon {
        transform: scale(1.1);
        opacity: 1;
      }

      .section-title {
        margin: 40px 0 16px;
        font-size: 1rem;
        font-weight: 500;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 1px;
      }
    </style>
  </head>

  <body class={bodyClass}>
    <slot />
  </body>
</html>
