---
import Layout from '../layouts/Layout.astro';

const name = '\u{1D593}\u{1D594}\u{1D586}\u{1D58D}\u30B7\u2671';
---

<Layout title={`Account \u2022 ${name}`} bodyClass="inner-page">
  <div class="inner-wrap">
    <div class="top">
      <a class="back" href="/">&#8592; back</a>
    </div>

    <h1>account sync</h1>
    <div class="sub">
      Login with Twitch and Discord to save connected profile data for the site.
    </div>

    <div class="profile-card" id="account-status">
      <div class="profile-row">
        <div class="avatar">A</div>
        <div>
          <h2>Connect your accounts</h2>
          <p>This page saves basic connected-account data after OAuth login is configured.</p>
        </div>
      </div>
    </div>

    <div class="button-row">
      <a class="button" href="/api/auth/twitch/start">Login with Twitch</a>
      <a class="button secondary" href="/api/auth/discord/start">Login with Discord</a>
    </div>

    <h2 class="section-title">saved data</h2>
    <div class="grid" id="saved-data">
      <div class="card">
        <h3>Loading</h3>
        <p>Checking saved account data...</p>
      </div>
    </div>

    <div class="footer">
      <p>&#169; 2026 {name}. All rights reserved.</p>
    </div>
  </div>

  <script>
    const savedData = document.querySelector('#saved-data');

    fetch('/api/auth/session')
      .then((response) => response.json())
      .then((session) => {
        if (!savedData) return;

        const twitch = session.twitch
          ? `<div class="card"><h3>Twitch</h3><p>@${session.twitch.login || session.twitch.display_name}</p></div>`
          : '<div class="card"><h3>Twitch</h3><p>Not connected yet.</p></div>';

        const discord = session.discord
          ? `<div class="card"><h3>Discord</h3><p>${session.discord.username}</p></div>`
          : '<div class="card"><h3>Discord</h3><p>Not connected yet.</p></div>';

        savedData.innerHTML = twitch + discord;
      })
      .catch(() => {
        if (!savedData) return;
        savedData.innerHTML = '<div class="card"><h3>Unavailable</h3><p>Could not load saved account data.</p></div>';
      });
  </script>
</Layout>
