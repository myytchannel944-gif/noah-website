---
import Layout from '../layouts/Layout.astro';

const name = '\u{1D593}\u{1D594}\u{1D586}\u{1D58D}\u30B7\u2671';
---

<Layout title={`Projects \u2022 ${name}`} bodyClass="inner-page">
  <div class="inner-wrap">
    <div class="top">
      <a class="back" href="/">&#8592; back</a>
    </div>

    <h1>projects</h1>
    <div class="sub">
      small projects I'm working on or made
    </div>

    <h2 class="section-title">what I made</h2>

    <div class="grid">
      <a href="#" class="card-link">
        <div class="card">
          <div class="card-row">
            <img src="/assets/chatbot.avif" class="icon" alt="" />
            <div>
              <h3>TimmySudo Twitch Bot</h3>
              <p>Twitch utility chatbot made for TimmySudo streams.</p>
            </div>
          </div>
        </div>
      </a>

      <a href="#" class="card-link">
        <div class="card">
          <div class="card-row">
            <img src="/assets/mod.avif" class="icon" alt="" />
            <div>
              <h3>Timmy Sudo Website</h3>
              <p>Personal website and live desk for TimmySudo.</p>
            </div>
          </div>
        </div>
      </a>
    </div>

    <div class="footer">
      <p>&#169; 2026 {name}. All rights reserved.</p>
    </div>
  </div>
</Layout>
