---
import Layout from '../layouts/Layout.astro';

const name = '\u{1D593}\u{1D594}\u{1D586}\u{1D58D}\u30B7\u2671';
---

<Layout title={`Projects • ${name}`} bodyClass="inner-page">
  <div class="inner-wrap">
    <div class="top">
      <a class="back" href="/">← back</a>
    </div>

    <h1>projects</h1>
    <div class="sub">
      small projects I'm working on or made
    </div>

    <h2 class="section-title">what I made</h2>

    <div class="grid">
      <a href="https://bot.itsbr0dyy.dev" target="_blank" class="card-link">
        <div class="card">
          <div class="card-row">
            <img src="/assets/chatbot.avif" class="icon" alt="" />
            <div>
              <h3>poggSpin</h3>
              <p>Twitch utility chatbot made for all your streaming needs.</p>
            </div>
          </div>
        </div>
      </a>

      <a href="https://roles.itsbr0dyy.dev" target="_blank" class="card-link">
        <div class="card">
          <div class="card-row">
            <img src="/assets/mod.avif" class="icon" alt="" />
            <div>
              <h3>TwitchRoles</h3>
              <p>check which users have mod/vip/founder in a Twitch channel.</p>
            </div>
          </div>
        </div>
      </a>
    </div>

    <h2 class="section-title">contributed to</h2>

    <div class="grid">
      <a href="https://potat.app" target="_blank" class="card-link">
        <div class="card">
          <div class="card-row">
            <img src="/assets/tatoExplode.gif" class="icon" alt="" />
            <div>
              <h3>PotatBotat</h3>
              <p>An emote, entertainment, and utility Twitch chatbot (contributed to website)</p>
            </div>
          </div>
        </div>
      </a>
    </div>

    <div class="footer">
      <p>© 2026 {name}. All rights reserved.</p>
    </div>
  </div>
</Layout>
