---
import Layout from '../layouts/Layout.astro';

const name = '\u{1D593}\u{1D594}\u{1D586}\u{1D58D}\u30B7\u2671';
---

<Layout title={name}>
  <div class="enter-screen" id="enter-screen">
    <button class="enter-button" id="enter-button" type="button">
      enter
    </button>
    <span>sound on</span>
  </div>

  <div class="home-wrap">
    <section class="hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Twitch moderation / stream tools / code</p>
        <h1>{name}</h1>
        <p>
          I help Twitch communities run smoother with moderation, stream setup knowledge,
          and custom web projects built around creators.
        </p>

        <div class="roles">
          <span class="pill">Moderator</span>
          <span class="pill">Twitch expert</span>
          <span class="pill">Code expert</span>
        </div>

        <div class="links">
          <a href="/projects">View Work</a>
          <a href="/twitch">Twitch</a>
          <a href="/discord">Discord</a>
          <a href="/about">About</a>
        </div>
      </div>

      <div class="featured-strip">
        <div class="mini-card">
          <span>Twitch</span>
          <strong>@timmyandshawnskid</strong>
        </div>
        <div class="mini-card">
          <span>Discord</span>
          <strong>noahisontopfr</strong>
        </div>
        <div class="mini-card">
          <span>Mod For</span>
          <strong>8 Twitch channels</strong>
        </div>
      </div>
    </section>

    <section class="portfolio-section">
      <div class="portfolio-head">
        <h2>featured work</h2>
        <p>Streamer-focused projects and tools made to keep communities organized and easier to run.</p>
      </div>
      <div class="portfolio-grid">
        <div class="portfolio-card">
          <h3>TimmySudo Twitch Bot</h3>
          <p>A Twitch utility bot project for commands, moderation help, and stream workflow ideas.</p>
          <a href="/projects">Open project</a>
        </div>
        <div class="portfolio-card">
          <h3>Timmy Sudo Website</h3>
          <p>A clean live desk and personal web presence built around a creator brand.</p>
          <a href="/projects">Open project</a>
        </div>
      </div>
    </section>

    <section class="portfolio-section">
      <div class="portfolio-head">
        <h2>community</h2>
        <p>Quick paths to the places where I help, moderate, and connect with people.</p>
      </div>
      <div class="portfolio-grid">
        <div class="portfolio-card">
          <h3>Twitch profile</h3>
          <p>Follow the channel and see the communities I moderate for.</p>
          <a href="/twitch">Go to Twitch page</a>
        </div>
        <div class="portfolio-card">
          <h3>Discord profile</h3>
          <p>Add me for stream talk, bot ideas, code help, and community stuff.</p>
          <a href="/discord">Go to Discord page</a>
        </div>
      </div>
    </section>

    <div class="home-footer">
      &#169; 2026 {name}. All rights reserved.
    </div>
  </div>

  <script>
    const enterScreen = document.querySelector('#enter-screen');
    const enterButton = document.querySelector('#enter-button');
    const introAudio = document.querySelector('#intro-audio');

    enterButton?.addEventListener('click', async () => {
      if (introAudio instanceof HTMLAudioElement) {
        introAudio.currentTime = Number(introAudio.dataset.start || 0);
        introAudio.volume = 0.55;

        try {
          await introAudio.play();
        } catch {
          enterButton.textContent = 'audio missing';
        }
      }

      enterScreen?.classList.add('is-hidden');
    });
  </script>
</Layout>
